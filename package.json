{
  "name": "@vladnet14/supercell-api",
  "version": "3.1.0",
  "description": "A comprehensive TypeScript library for interacting with Supercell game APIs (Clash of Clans, Clash Royale, Brawl Stars)",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DARKPIX404/supercell-api.git"
  },
  "bugs": {
    "url": "https://github.com/DARKPIX404/supercell-api/issues"
  },
  "homepage": "https://darkpix404.github.io/supercell-api/",
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "supercell",
    "api",
    "brawl-stars",
    "clash-of-clans",
    "clash-royale",
    "game-api",
    "typescript"
  ],
  "author": "Vladislav Borodatyi <vlad.borodaty228032qw@gmail.com>",
  "license": "Apache-2.0",
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0"
  }
}
